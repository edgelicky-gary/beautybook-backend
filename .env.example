# ================================================
# BeautyBook 環境變數設定
# 複製此檔案為 .env 並填入真實值
# ================================================

NODE_ENV=development
PORT=3000

# MongoDB 資料庫
# 免費申請: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://用戶名:密碼@cluster.mongodb.net/beautybook

# JWT 密鑰（自己設定一串隨機字串）
JWT_SECRET=your_super_secret_key_here_123456

# 前後端網址
FRONTEND_URL=http://localhost:19006
BACKEND_URL=http://localhost:3000

# LINE Pay
# 申請: https://pay.line.me/tw/merchants/apply
LINE_PAY_CHANNEL_ID=your_line_pay_channel_id
LINE_PAY_CHANNEL_SECRET=your_line_pay_channel_secret

# LINE Login
# 申請: https://developers.line.biz/console/
LINE_LOGIN_CHANNEL_ID=your_line_login_channel_id
LINE_LOGIN_CHANNEL_SECRET=your_line_login_channel_secret

# LINE Messaging API (推播通知)
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# 藍新金流 (信用卡)
# 申請: https://www.newebpay.com/
NEWEBPAY_MERCHANT_ID=your_merchant_id
NEWEBPAY_HASH_KEY=your_hash_key
NEWEBPAY_HASH_IV=your_hash_iv

# 街口支付
# 申請: https://www.jkopay.com/merchant
JKOPAY_MERCHANT_CODE=your_merchant_code
JKOPAY_SECRET_KEY=your_secret_key
